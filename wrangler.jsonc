/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "campaign-risk-monitor",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},

	/**
	 * Durable Objects
	 * https://developers.cloudflare.com/durable-objects/
	 *
	 * To add a new DO:
	 * 1. Create the class in workers/ (see workers/example-do.ts)
	 * 2. Export it from workers/app.ts
	 * 3. Add binding below
	 * 4. Add migration (increment tag, add new_sqlite_classes for SQLite DOs)
	 * 5. Run `bun wrangler types` to update Env types
	 */
	"durable_objects": {
		"bindings": [
			{ "name": "CAMPAIGN_DO", "class_name": "CampaignDO" }
		]
	},
	"migrations": [
		{ "tag": "v1", "new_sqlite_classes": ["CampaignDO"] }
	],

	/**
	 * R2 Object Storage
	 * https://developers.cloudflare.com/r2/
	 *
	 * Use any bucket name — buckets are created automatically on first use.
	 * Access via env.MY_BUCKET.get(), .put(), .list(), .delete()
	 */
	// "r2_buckets": [
	// 	{ "binding": "MY_BUCKET", "bucket_name": "starter-uploads" }
	// ],

	/**
	 * Workers AI
	 * https://developers.cloudflare.com/workers-ai/
	 *
	 * Optional: declare a native AI binding for `workers-ai-provider`
	 * (`createWorkersAI({ binding: env.AI })`).
	 * In camelAI deploys, this is virtualized and rewritten to the platform AI entrypoint.
	 */
	"ai": { "binding": "AI" },

	/**
	 * Runtime variables available in loader/action context via context.cloudflare.env
	 */
	"vars": {
		"AI_VIRTUAL_MODEL": "dynamic/auto",
		"VALUE_FROM_CLOUDFLARE": "Starter template running on Cloudflare"
		// Optional local fallback for template DATA_PROXY shim:
		// "DATA_PROXY_URL": "http://host.docker.internal:8081/proxy/<thread-id>/api"
	},

	/**
	 * Smart Placement
	 * https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
	 */
	// "placement": {  "mode": "smart" }

	/**
	 * Static Assets
	 * https://developers.cloudflare.com/workers/static-assets/binding/
	 */
	"assets": { "directory": "./public/", "binding": "ASSETS" },

	/**
	 * DATA_PROXY service binding:
	 * - Locally, this binds to the template's LocalDataProxyService entrypoint.
	 * - In camelAI deploys, this binding is virtualized/replaced with platform DataProxyService.
	 */
	"services": [
		{ "binding": "DATA_PROXY", "service": "campaign-risk-monitor", "entrypoint": "LocalDataProxyService" }
	]
}
